<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page</title>

<style>
    h1{
        text-align: center;
    }

    table{
        border-collapse: collapse;
        width: 400px;
        margin: auto;
    }

    td,th{
        border:1px solid black;
        padding:10px;
        text-align:center;
    }
</style>
</head>
<body>

    <h1>Welcome To Home Page</h1>

    <table>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Course</th>
        </tr>

        <% Students.map((student)=>{ %>

            <tr>
                <td><%= student.id %></td>
                <td><%= student.name %></td>
                <td><%= student.courseName %></td>
            </tr>

        <% }) %>

    </table>

</body>
</html>